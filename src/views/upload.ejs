<%- include('partials/auth-head', { title: 'Upload Profile Images' }) %>
<body>
  <div class="auth-shell upload-shell">
    <section class="auth-card upload-card" aria-label="Image upload workspace">
      <div class="brand"><strong>Profile Photos</strong></div>
      <h1>Upload your photos</h1>
      <p class="footer-note">Select between 3 and 6 profile photos. Drag & drop, browse files, or <strong>take a live selfie</strong>.</p>

      <div id="message" class="message-box" role="status" aria-live="polite"></div>

      <form id="upload-form" class="upload-form" novalidate>

        <!--
          The real file input lives OUTSIDE the drop zone and is hidden off-screen
          (not display:none — must remain interactive for the <label> to work).
        -->
        <input
          id="images"
          name="images"
          type="file"
          accept="image/jpeg,image/png,image/webp,image/gif"
          multiple
          class="file-input-sr"
          aria-label="Select images (hold Ctrl or Cmd to pick multiple)"
        />

        <!-- Drop zone -->
        <label id="drop-zone" for="images" class="drop-zone" tabindex="0" aria-label="Click or drag images here to select them">
          <div class="drop-zone-inner">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="17 8 12 3 7 8"/>
              <line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
            <p>Drag &amp; drop images here</p>
            <span class="drop-zone-hint">or click to browse &amp; pick multiple</span>
          </div>
        </label>

        <!-- Selfie / Camera button -->
        <button type="button" id="open-camera-btn" class="camera-btn" aria-haspopup="dialog">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
            <circle cx="12" cy="13" r="4"/>
          </svg>
          Take a selfie
        </button>

        <!-- Image count indicator -->
        <div class="count-bar">
          <span id="count-label" class="count-label">0 / 6 selected</span>
          <span id="count-hint" class="count-hint">Need at least 3 photos</span>
        </div>

        <!-- Selected image previews -->
        <div id="preview-section" class="preview-block" hidden>
          <h2>Selected photos <span id="preview-badge" class="badge">0</span></h2>
          <div id="preview" class="preview-grid"></div>
        </div>

        <button id="submit-btn" type="submit" disabled>Upload photos</button>
      </form>

      <!-- Uploaded images (shown after successful upload) -->
      <div id="uploaded-section" class="preview-block" hidden>
        <h2>Uploaded to Cloudinary <span id="uploaded-badge" class="badge badge-success">0</span></h2>
        <div id="uploaded-list" class="preview-grid"></div>
      </div>

      <div class="page-links">
        <a href="/dashboard">← Back to dashboard</a>
      </div>
    </section>
  </div>

  <!-- ═══════════════════════════════════════════════
       CAMERA MODAL
  ═══════════════════════════════════════════════ -->
  <dialog id="camera-modal" class="camera-modal" aria-label="Take a selfie" aria-modal="true">
    <div class="camera-modal-inner">

      <!-- Header -->
      <div class="camera-modal-header">
        <span class="camera-modal-title">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
            <circle cx="12" cy="13" r="4"/>
          </svg>
          Live Camera
        </span>
        <button type="button" id="close-camera-btn" class="modal-close-btn" aria-label="Close camera">✕</button>
      </div>

      <!-- Camera error message (shown if getUserMedia fails) -->
      <div id="camera-error" class="camera-error" hidden>
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <p id="camera-error-text">Camera access was denied. Please allow camera permissions and try again.</p>
      </div>

      <!-- Live video feed -->
      <div class="camera-feed-wrapper" id="camera-feed-wrapper">
        <video id="camera-feed" autoplay playsinline muted aria-label="Live camera preview"></video>

        <!-- Countdown overlay -->
        <div id="countdown-overlay" class="countdown-overlay" hidden>
          <span id="countdown-number" class="countdown-number">3</span>
        </div>

        <!-- Snap flash effect -->
        <div id="snap-flash" class="snap-flash" hidden></div>
      </div>

      <!-- Hidden canvas for frame capture -->
      <canvas id="capture-canvas" hidden></canvas>

      <!-- Snap controls row -->
      <div class="camera-controls">
        <button type="button" id="switch-camera-btn" class="ctrl-btn ctrl-switch" title="Switch camera" aria-label="Switch front/rear camera">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M1 4v6h6"/>
            <path d="M23 20v-6h-6"/>
            <path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10"/>
            <path d="M3.51 15a9 9 0 0 0 14.85 3.36L23 14"/>
          </svg>
        </button>

        <button type="button" id="snap-btn" class="ctrl-btn ctrl-snap" aria-label="Take photo" disabled>
          <span class="snap-ring"></span>
        </button>

        <button type="button" id="timer-btn" class="ctrl-btn ctrl-timer" title="3-second timer" aria-label="Toggle 3-second countdown timer" aria-pressed="false">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="13" r="8"/>
            <path d="M12 9v4l2 2"/>
            <path d="M9 2h6"/>
            <path d="M12 2v2"/>
          </svg>
          <span class="timer-label">3s</span>
        </button>
      </div>

      <!-- Selfie strip (captured frames) -->
      <div id="selfie-strip-wrapper" class="selfie-strip-wrapper" hidden>
        <p class="selfie-strip-label">Captured <span id="selfie-count">0</span></p>
        <div id="selfie-strip" class="selfie-strip" role="list" aria-label="Captured selfies"></div>
      </div>

      <!-- Modal action buttons -->
      <div class="camera-modal-actions">
        <button type="button" id="cancel-camera-btn" class="modal-action-btn modal-action-cancel">Cancel</button>
        <button type="button" id="use-selfies-btn" class="modal-action-btn modal-action-use" disabled>
          Use these photos
          <span id="use-count-badge" class="use-count-badge">0</span>
        </button>
      </div>

    </div>
  </dialog>

  <style>
    /* ── Upload-page specific overrides ── */
    .upload-shell {
      width: min(720px, 100%);
    }

    .upload-card {
      width: 100%;
    }

    /* Drop zone */
    .drop-zone {
      position: relative;
      border: 2px dashed rgba(56, 189, 248, 0.35);
      border-radius: 20px;
      padding: 2.4rem 1.5rem;
      text-align: center;
      cursor: pointer;
      transition: border-color 200ms ease, background 200ms ease, box-shadow 200ms ease;
      background: rgba(56, 189, 248, 0.04);
    }

    .drop-zone:hover,
    .drop-zone:focus,
    .drop-zone.drag-over {
      border-color: var(--accent);
      background: rgba(56, 189, 248, 0.10);
      box-shadow: 0 0 0 6px rgba(56, 189, 248, 0.10);
      outline: none;
    }

    .drop-zone-inner {
      pointer-events: none;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.55rem;
      color: var(--muted);
    }

    .drop-zone-inner svg {
      color: var(--accent);
      opacity: 0.85;
    }

    .drop-zone-inner p {
      margin: 0;
      font-size: 1rem;
      color: #cbd5e1;
    }

    .drop-zone-hint {
      font-size: 0.82rem;
      color: var(--accent);
      font-weight: 600;
      letter-spacing: 0.02em;
    }

    /*
      Hide the real file input off-screen (screen-reader accessible).
      DO NOT use display:none or visibility:hidden — the input must remain
      interactive so the associated <label for="images"> can activate it.
    */
    .file-input-sr {
      position: absolute !important;
      width: 1px !important;
      height: 1px !important;
      min-height: 1px !important;
      padding: 0 !important;
      margin: -1px !important;
      overflow: hidden !important;
      clip: rect(0, 0, 0, 0) !important;
      white-space: nowrap !important;
      border: 0 !important;
    }

    /* ── Camera button ── */
    .camera-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.55rem;
      width: 100%;
      min-height: 52px;
      border-radius: 16px;
      border: 1px solid rgba(168, 85, 247, 0.45);
      background: linear-gradient(135deg, rgba(168, 85, 247, 0.18), rgba(139, 92, 246, 0.12));
      color: #c4b5fd;
      font-weight: 700;
      font-size: 0.97rem;
      letter-spacing: 0.01em;
      cursor: pointer;
      transition: background 200ms ease, border-color 200ms ease,
                  box-shadow 200ms ease, transform 180ms ease;
      box-shadow: 0 0 0 0 rgba(168, 85, 247, 0);
    }

    .camera-btn:hover {
      background: linear-gradient(135deg, rgba(168, 85, 247, 0.32), rgba(139, 92, 246, 0.22));
      border-color: rgba(168, 85, 247, 0.75);
      box-shadow: 0 0 0 6px rgba(168, 85, 247, 0.12), 0 12px 28px rgba(168, 85, 247, 0.18);
      transform: translateY(-1px);
    }

    .camera-btn:active {
      transform: translateY(0);
    }

    /* Count bar */
    .count-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 0.4rem;
      margin-top: -0.25rem;
    }

    .count-label {
      font-size: 0.9rem;
      font-weight: 700;
      color: #f8fafc;
    }

    .count-hint {
      font-size: 0.82rem;
      color: var(--muted);
    }

    .count-hint.ready {
      color: var(--success);
    }

    /* Preview grid */
    .preview-block {
      margin-top: 1.4rem;
    }

    .preview-block h2 {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 1rem;
      margin: 0 0 0.85rem;
      color: #f8fafc;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 22px;
      height: 22px;
      padding: 0 6px;
      border-radius: 99px;
      background: rgba(56, 189, 248, 0.22);
      color: var(--accent);
      font-size: 0.78rem;
      font-weight: 700;
    }

    .badge-success {
      background: rgba(34, 197, 94, 0.22);
      color: var(--success);
    }

    .preview-grid {
      display: grid;
      gap: 0.75rem;
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    }

    /* Preview card — image thumbnail */
    .preview-card {
      position: relative;
      border-radius: 16px;
      overflow: hidden;
      background: rgba(15, 23, 42, 0.72);
      border: 1px solid rgba(148, 163, 184, 0.16);
      aspect-ratio: 1 / 1;
      display: flex;
      flex-direction: column;
    }

    .preview-card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 300ms ease;
    }

    .preview-card:hover img {
      transform: scale(1.04);
    }

    /* Remove button overlay */
    .preview-card .remove-btn {
      position: absolute;
      top: 6px;
      right: 6px;
      width: 28px;
      min-height: 28px;
      height: 28px;
      border-radius: 50%;
      background: rgba(15, 23, 42, 0.82);
      border: 1px solid rgba(248, 113, 113, 0.45);
      color: #f87171;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      font-size: 0.75rem;
      font-weight: 700;
      transition: background 180ms ease, transform 180ms ease;
      padding: 0;
    }

    .preview-card .remove-btn:hover {
      background: rgba(248, 113, 113, 0.22);
      transform: scale(1.12);
    }

    /* Selfie badge overlay on preview cards */
    .preview-card.is-selfie::before {
      content: '📸';
      position: absolute;
      top: 6px;
      left: 6px;
      font-size: 0.8rem;
      line-height: 1;
      background: rgba(168, 85, 247, 0.85);
      border-radius: 99px;
      padding: 3px 6px;
      z-index: 1;
    }

    /* File name label at bottom of preview card */
    .preview-card .file-label {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 4px 8px;
      background: rgba(2, 6, 23, 0.72);
      font-size: 0.72rem;
      color: #94a3b8;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      text-align: center;
    }

    /* Uploaded card (Cloudinary) */
    .uploaded-card {
      position: relative;
      border-radius: 16px;
      overflow: hidden;
      background: rgba(15, 23, 42, 0.72);
      border: 1px solid rgba(34, 197, 94, 0.22);
      aspect-ratio: 1 / 1;
      display: flex;
      flex-direction: column;
    }

    .uploaded-card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 300ms ease;
    }

    .uploaded-card:hover img {
      transform: scale(1.04);
    }

    .uploaded-card a.open-link {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 5px 8px;
      background: rgba(2, 6, 23, 0.75);
      font-size: 0.72rem;
      color: var(--accent);
      font-weight: 600;
      text-align: center;
      text-decoration: none;
      transition: background 180ms ease;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .uploaded-card a.open-link:hover {
      background: rgba(14, 165, 233, 0.25);
    }

    /* Success tick overlay on uploaded cards */
    .uploaded-card::after {
      content: '✓';
      position: absolute;
      top: 6px;
      right: 6px;
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: rgba(34, 197, 94, 0.85);
      color: #fff;
      font-size: 0.7rem;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
    }

    /* Submit button overrides */
    #submit-btn {
      margin-top: 0.5rem;
    }

    #submit-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none;
    }

    @media (max-width: 520px) {
      .preview-grid {
        grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
      }
    }

    /* ═══════════════════════════════════════════
       CAMERA MODAL STYLES
    ═══════════════════════════════════════════ */

    /* Native <dialog> reset + backdrop */
    .camera-modal {
      position: fixed;
      inset: 0;
      margin: auto;
      padding: 0;
      border: none;
      border-radius: 28px;
      background: transparent;
      width: min(680px, calc(100vw - 32px));
      max-height: calc(100dvh - 32px);
      overflow: hidden;
      z-index: 1000;
    }

    .camera-modal::backdrop {
      background: rgba(2, 6, 23, 0.82);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
    }

    /* Animate modal open */
    @keyframes modalIn {
      from { opacity: 0; transform: scale(0.94) translateY(12px); }
      to   { opacity: 1; transform: scale(1)    translateY(0);    }
    }

    .camera-modal[open] {
      animation: modalIn 280ms cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    /* Inner card with glassmorphism */
    .camera-modal-inner {
      background: linear-gradient(145deg,
        rgba(15, 23, 42, 0.96) 0%,
        rgba(20, 28, 52, 0.98) 100%
      );
      border: 1px solid rgba(148, 163, 184, 0.18);
      border-radius: 28px;
      padding: 24px;
      display: flex;
      flex-direction: column;
      gap: 16px;
      box-shadow: 0 40px 100px rgba(0, 0, 0, 0.5),
                  0 0 0 1px rgba(168, 85, 247, 0.12);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      overflow-y: auto;
      max-height: calc(100dvh - 64px);
    }

    /* Modal header */
    .camera-modal-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .camera-modal-title {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 1rem;
      font-weight: 700;
      color: #c4b5fd;
      letter-spacing: 0.02em;
    }

    .modal-close-btn {
      width: 36px;
      min-height: 36px;
      height: 36px;
      border-radius: 50%;
      border: 1px solid rgba(148, 163, 184, 0.2);
      background: rgba(15, 23, 42, 0.6);
      color: var(--muted);
      font-size: 0.85rem;
      font-weight: 700;
      cursor: pointer;
      transition: background 180ms ease, color 180ms ease, transform 180ms ease;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0;
    }

    .modal-close-btn:hover {
      background: rgba(248, 113, 113, 0.18);
      color: #f87171;
      transform: scale(1.08);
    }

    /* Camera error state */
    .camera-error {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
      padding: 2rem 1.5rem;
      text-align: center;
      background: rgba(248, 113, 113, 0.08);
      border: 1px solid rgba(248, 113, 113, 0.2);
      border-radius: 18px;
      color: #fca5a5;
    }

    .camera-error svg {
      color: #f87171;
      opacity: 0.85;
    }

    .camera-error p {
      margin: 0;
      font-size: 0.93rem;
      line-height: 1.55;
      color: #fecaca;
    }

    /* Video feed wrapper */
    .camera-feed-wrapper {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 9;
      border-radius: 20px;
      overflow: hidden;
      background: #020617;
      border: 1px solid rgba(168, 85, 247, 0.2);
      box-shadow: 0 0 0 1px rgba(168, 85, 247, 0.08),
                  inset 0 0 40px rgba(0, 0, 0, 0.4);
    }

    #camera-feed {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transform: scaleX(-1); /* Mirror for selfie UX */
      border-radius: 20px;
    }

    /* Countdown overlay */
    .countdown-overlay {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(2, 6, 23, 0.6);
      z-index: 10;
    }

    @keyframes countPulse {
      0%   { transform: scale(1.4); opacity: 0; }
      20%  { transform: scale(1);   opacity: 1; }
      80%  { transform: scale(0.9); opacity: 1; }
      100% { transform: scale(0.7); opacity: 0; }
    }

    .countdown-number {
      font-size: clamp(5rem, 18vw, 8rem);
      font-weight: 900;
      color: #fff;
      text-shadow: 0 0 40px rgba(168, 85, 247, 0.9),
                   0 0 80px rgba(168, 85, 247, 0.5);
      animation: countPulse 900ms ease forwards;
    }

    /* Snap flash */
    @keyframes snapFlash {
      0%   { opacity: 0.85; }
      100% { opacity: 0;    }
    }

    .snap-flash {
      position: absolute;
      inset: 0;
      background: #fff;
      border-radius: 20px;
      animation: snapFlash 200ms ease forwards;
      pointer-events: none;
      z-index: 11;
    }

    /* Camera controls row */
    .camera-controls {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1.5rem;
    }

    /* Generic control button */
    .ctrl-btn {
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: transform 180ms ease, background 180ms ease, box-shadow 180ms ease;
      flex-shrink: 0;
    }

    /* Switch camera button */
    .ctrl-switch {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: rgba(56, 189, 248, 0.12);
      border: 1px solid rgba(56, 189, 248, 0.3);
      color: var(--accent);
    }

    .ctrl-switch:hover {
      background: rgba(56, 189, 248, 0.22);
      transform: rotate(45deg) scale(1.05);
    }

    /* Snap button (main shutter) */
    .ctrl-snap {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      background: linear-gradient(135deg, #a855f7, #7c3aed);
      box-shadow: 0 0 0 5px rgba(168, 85, 247, 0.22),
                  0 8px 24px rgba(168, 85, 247, 0.4);
      padding: 0;
    }

    .ctrl-snap:hover:not(:disabled) {
      transform: scale(1.08);
      box-shadow: 0 0 0 8px rgba(168, 85, 247, 0.25),
                  0 12px 32px rgba(168, 85, 247, 0.5);
    }

    .ctrl-snap:active:not(:disabled) {
      transform: scale(0.94);
    }

    .ctrl-snap:disabled {
      opacity: 0.4;
      cursor: not-allowed;
      transform: none;
    }

    /* Snap ring (inner white circle) */
    .snap-ring {
      display: block;
      width: 52px;
      height: 52px;
      border-radius: 50%;
      border: 3px solid rgba(255, 255, 255, 0.9);
      background: rgba(255, 255, 255, 0.12);
    }

    /* Timer button */
    .ctrl-timer {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: rgba(148, 163, 184, 0.08);
      border: 1px solid rgba(148, 163, 184, 0.2);
      color: var(--muted);
      flex-direction: column;
      gap: 1px;
      font-size: 0;
    }

    .ctrl-timer .timer-label {
      font-size: 0.6rem;
      font-weight: 700;
      color: var(--muted);
      letter-spacing: 0.04em;
    }

    .ctrl-timer:hover {
      background: rgba(168, 85, 247, 0.14);
      border-color: rgba(168, 85, 247, 0.4);
      color: #c4b5fd;
    }

    .ctrl-timer:hover .timer-label {
      color: #c4b5fd;
    }

    .ctrl-timer[aria-pressed="true"] {
      background: rgba(168, 85, 247, 0.22);
      border-color: rgba(168, 85, 247, 0.6);
      color: #c4b5fd;
      box-shadow: 0 0 0 4px rgba(168, 85, 247, 0.14);
    }

    .ctrl-timer[aria-pressed="true"] .timer-label {
      color: #c4b5fd;
    }

    /* Selfie strip */
    .selfie-strip-wrapper {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .selfie-strip-label {
      margin: 0;
      font-size: 0.82rem;
      color: var(--muted);
      font-weight: 600;
    }

    .selfie-strip {
      display: flex;
      gap: 10px;
      overflow-x: auto;
      padding-bottom: 4px;
      scrollbar-width: thin;
      scrollbar-color: rgba(168, 85, 247, 0.3) transparent;
    }

    .selfie-strip::-webkit-scrollbar {
      height: 4px;
    }

    .selfie-strip::-webkit-scrollbar-thumb {
      background: rgba(168, 85, 247, 0.3);
      border-radius: 2px;
    }

    /* Each selfie thumbnail in the strip */
    .selfie-thumb {
      position: relative;
      flex-shrink: 0;
      width: 80px;
      height: 80px;
      border-radius: 14px;
      overflow: hidden;
      border: 2px solid rgba(168, 85, 247, 0.4);
      cursor: pointer;
      transition: border-color 180ms ease, transform 180ms ease;
    }

    .selfie-thumb:hover {
      border-color: rgba(168, 85, 247, 0.9);
      transform: scale(1.05);
    }

    @keyframes thumbIn {
      from { opacity: 0; transform: scale(0.7); }
      to   { opacity: 1; transform: scale(1);   }
    }

    .selfie-thumb {
      animation: thumbIn 250ms cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .selfie-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transform: scaleX(-1); /* Mirror to match live feed */
    }

    .selfie-thumb-remove {
      position: absolute;
      top: 3px;
      right: 3px;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: rgba(15, 23, 42, 0.85);
      border: 1px solid rgba(248, 113, 113, 0.5);
      color: #f87171;
      font-size: 0.65rem;
      font-weight: 700;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      transition: background 150ms ease;
    }

    .selfie-thumb-remove:hover {
      background: rgba(248, 113, 113, 0.28);
    }

    /* Modal action buttons */
    .camera-modal-actions {
      display: flex;
      gap: 12px;
    }

    .modal-action-btn {
      flex: 1;
      min-height: 50px;
      border-radius: 14px;
      font-weight: 700;
      font-size: 0.95rem;
      cursor: pointer;
      border: none;
      transition: background 180ms ease, transform 180ms ease, box-shadow 180ms ease;
    }

    .modal-action-cancel {
      background: rgba(148, 163, 184, 0.1);
      color: var(--muted);
      border: 1px solid rgba(148, 163, 184, 0.2);
    }

    .modal-action-cancel:hover {
      background: rgba(148, 163, 184, 0.18);
      color: #f8fafc;
      transform: translateY(-1px);
    }

    .modal-action-use {
      background: linear-gradient(135deg, #a855f7, #7c3aed);
      color: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      box-shadow: 0 8px 20px rgba(168, 85, 247, 0.3);
    }

    .modal-action-use:hover:not(:disabled) {
      transform: translateY(-1px);
      box-shadow: 0 12px 28px rgba(168, 85, 247, 0.45);
    }

    .modal-action-use:disabled {
      opacity: 0.45;
      cursor: not-allowed;
      transform: none;
    }

    .use-count-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 22px;
      height: 22px;
      padding: 0 6px;
      border-radius: 99px;
      background: rgba(255, 255, 255, 0.25);
      font-size: 0.78rem;
      font-weight: 700;
    }
  </style>

  <script>
    'use strict';

    const MIN_IMAGES = 3;
    const MAX_IMAGES = 6;

    const dropZone     = document.getElementById('drop-zone');
    const fileInput    = document.getElementById('images');
    const preview      = document.getElementById('preview');
    const previewSect  = document.getElementById('preview-section');
    const previewBadge = document.getElementById('preview-badge');
    const countLabel   = document.getElementById('count-label');
    const countHint    = document.getElementById('count-hint');
    const uploadedList = document.getElementById('uploaded-list');
    const uploadedSect = document.getElementById('uploaded-section');
    const uploadedBadge= document.getElementById('uploaded-badge');
    const messageBox   = document.getElementById('message');
    const submitBtn    = document.getElementById('submit-btn');

    /** @type {File[]} */
    let selectedFiles = [];

    /* ─────────────── Messaging ─────────────── */
    function setMessage(text, type = 'success') {
      messageBox.textContent = text;
      messageBox.className = `message-box ${type}`;
    }

    function clearMessage() {
      messageBox.textContent = '';
      messageBox.className = 'message-box';
    }

    /* ─────────────── File management ─────────────── */
    function isDuplicate(file, list) {
      return list.some(
        (f) => f.name === file.name && f.size === file.size && f.lastModified === file.lastModified
      );
    }

    /**
     * @param {File[]} incoming
     * @param {boolean} [isSelfie=false]
     */
    function addFiles(incoming, isSelfie = false) {
      const files = Array.from(incoming || []);
      if (!files.length) return;

      clearMessage();

      const next = [...selectedFiles];
      let duplicates = 0;

      for (const file of files) {
        if (isDuplicate(file, next)) { duplicates++; continue; }
        if (next.length >= MAX_IMAGES) {
          setMessage(`Maximum ${MAX_IMAGES} photos allowed. Some files were not added.`, 'error');
          break;
        }
        // Tag selfies so we can badge them in the preview
        if (isSelfie) {
          Object.defineProperty(file, '_isSelfie', { value: true, writable: false });
        }
        next.push(file);
      }

      if (duplicates > 0 && !messageBox.classList.contains('error')) {
        setMessage(`${duplicates} duplicate file(s) were skipped.`, 'error');
      }

      selectedFiles = next;
      renderPreview();
    }

    function removeFile(index) {
      const card = preview.children[index];
      if (card) {
        const img = card.querySelector('img');
        if (img && img.src.startsWith('blob:')) URL.revokeObjectURL(img.src);
      }
      selectedFiles.splice(index, 1);
      clearMessage();
      renderPreview();
    }

    /* ─────────────── Render selected previews ─────────────── */
    function renderPreview() {
      Array.from(preview.querySelectorAll('img')).forEach((img) => {
        if (img.src.startsWith('blob:')) URL.revokeObjectURL(img.src);
      });

      preview.innerHTML = '';

      const count = selectedFiles.length;
      countLabel.textContent = `${count} / ${MAX_IMAGES} selected`;

      if (count === 0) {
        countHint.textContent = `Need at least ${MIN_IMAGES} photos`;
        countHint.className = 'count-hint';
        previewSect.hidden = true;
        submitBtn.disabled = true;
        return;
      }

      if (count < MIN_IMAGES) {
        countHint.textContent = `Need ${MIN_IMAGES - count} more photo${MIN_IMAGES - count !== 1 ? 's' : ''}`;
        countHint.className = 'count-hint';
      } else {
        countHint.textContent = count === MAX_IMAGES ? 'Maximum reached' : 'Ready to upload!';
        countHint.className = 'count-hint ready';
      }

      submitBtn.disabled = count < MIN_IMAGES;
      previewSect.hidden = false;
      previewBadge.textContent = count;

      selectedFiles.forEach((file, index) => {
        const objectUrl = URL.createObjectURL(file);

        const card = document.createElement('div');
        card.className = 'preview-card' + (file._isSelfie ? ' is-selfie' : '');

        const img = document.createElement('img');
        img.src = objectUrl;
        img.alt = file.name;
        img.loading = 'lazy';

        const label = document.createElement('span');
        label.className = 'file-label';
        label.textContent = file.name;

        const removeBtn = document.createElement('button');
        removeBtn.type = 'button';
        removeBtn.className = 'remove-btn';
        removeBtn.setAttribute('aria-label', `Remove ${file.name}`);
        removeBtn.textContent = '✕';
        removeBtn.addEventListener('click', () => removeFile(index));

        card.append(img, label, removeBtn);
        preview.appendChild(card);
      });
    }

    /* ─────────────── Render Cloudinary uploads ─────────────── */
    function renderUploaded(images) {
      uploadedList.innerHTML = '';

      if (!images || !images.length) {
        uploadedSect.hidden = true;
        return;
      }

      uploadedBadge.textContent = images.length;
      uploadedSect.hidden = false;

      images.forEach((image) => {
        const card = document.createElement('div');
        card.className = 'uploaded-card';

        const img = document.createElement('img');
        img.src = image.url;
        img.alt = image.publicId || 'Uploaded photo';
        img.loading = 'lazy';

        const link = document.createElement('a');
        link.href = image.url;
        link.target = '_blank';
        link.rel = 'noopener noreferrer';
        link.className = 'open-link';
        link.textContent = 'Open ↗';

        card.append(img, link);
        uploadedList.appendChild(card);
      });
    }

    /* ─────────────── Drag & drop ─────────────── */
    dropZone.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropZone.classList.add('drag-over');
    });

    dropZone.addEventListener('dragleave', () => {
      dropZone.classList.remove('drag-over');
    });

    dropZone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropZone.classList.remove('drag-over');
      addFiles(e.dataTransfer.files);
      fileInput.value = '';
    });

    dropZone.addEventListener('keydown', (e) => {
      if (e.key === ' ') {
        e.preventDefault();
      }
    });

    /* ─────────────── File input change ─────────────── */
    fileInput.addEventListener('change', (e) => {
      addFiles(e.target.files);
      e.target.value = '';
    });

    /* ─────────────── Form submit → upload to Cloudinary ─────────────── */
    document.getElementById('upload-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      clearMessage();

      if (selectedFiles.length < MIN_IMAGES || selectedFiles.length > MAX_IMAGES) {
        setMessage(`Please select between ${MIN_IMAGES} and ${MAX_IMAGES} photos before uploading.`, 'error');
        return;
      }

      const formData = new FormData();
      selectedFiles.forEach((file) => formData.append('images', file));

      submitBtn.disabled = true;
      submitBtn.textContent = 'Uploading…';

      try {
        const response = await fetch('/api/uploads', {
          method: 'POST',
          body: formData,
          credentials: 'same-origin'
        });

        const result = await response.json();

        if (!response.ok || !result.success) {
          throw new Error(result.message || 'Upload failed. Please try again.');
        }

        setMessage(`✓ ${result.data.count} photo${result.data.count !== 1 ? 's' : ''} uploaded successfully!`, 'success');

        Array.from(preview.querySelectorAll('img')).forEach((img) => {
          if (img.src.startsWith('blob:')) URL.revokeObjectURL(img.src);
        });
        selectedFiles = [];
        renderPreview();

        renderUploaded(result.data.images || []);
      } catch (err) {
        setMessage(err.message || 'Unable to upload photos right now. Please try again.', 'error');
      } finally {
        submitBtn.disabled = selectedFiles.length < MIN_IMAGES;
        submitBtn.textContent = 'Upload photos';
      }
    });

    /* ═══════════════════════════════════════════════════════════
       CAMERA / SELFIE SYSTEM  (MediaDevices API)
    ═══════════════════════════════════════════════════════════ */

    const cameraModal      = document.getElementById('camera-modal');
    const cameraFeed       = document.getElementById('camera-feed');
    const captureCanvas    = document.getElementById('capture-canvas');
    const snapBtn          = document.getElementById('snap-btn');
    const switchCameraBtn  = document.getElementById('switch-camera-btn');
    const timerBtn         = document.getElementById('timer-btn');
    const countdownOverlay = document.getElementById('countdown-overlay');
    const countdownNumber  = document.getElementById('countdown-number');
    const snapFlash        = document.getElementById('snap-flash');
    const selfieStrip      = document.getElementById('selfie-strip');
    const selfieStripWrap  = document.getElementById('selfie-strip-wrapper');
    const selfieCountEl    = document.getElementById('selfie-count');
    const useSelfiesBtn    = document.getElementById('use-selfies-btn');
    const useCountBadge    = document.getElementById('use-count-badge');
    const cameraError      = document.getElementById('camera-error');
    const cameraErrorText  = document.getElementById('camera-error-text');
    const cameraFeedWrap   = document.getElementById('camera-feed-wrapper');
    const openCameraBtn    = document.getElementById('open-camera-btn');
    const closeCameraBtn   = document.getElementById('close-camera-btn');
    const cancelCameraBtn  = document.getElementById('cancel-camera-btn');

    /** @type {MediaStream|null} */
    let activeStream = null;
    /** @type {'user'|'environment'} */
    let facingMode = 'user';
    /** @type {boolean} */
    let timerEnabled = false;
    /** @type {number|null} */
    let countdownTimer = null;
    /** @type {{ file: File, objectUrl: string }[]} */
    let capturedSelfies = [];
    /** @type {number} */
    let selfieSerial = 0;

    /* ── Open camera ── */
    openCameraBtn.addEventListener('click', () => {
      // Reset selfies from previous session
      capturedSelfies.forEach((s) => URL.revokeObjectURL(s.objectUrl));
      capturedSelfies = [];
      selfieSerial = 0;
      renderSelfieStrip();

      cameraModal.showModal();
      startCamera();
    });

    /** Requests camera access and attaches the stream to the <video> */
    async function startCamera() {
      stopCamera();
      showCameraError(false);

      try {
        const constraints = {
          video: {
            facingMode,
            width:  { ideal: 1280 },
            height: { ideal: 720 }
          },
          audio: false
        };

        activeStream = await navigator.mediaDevices.getUserMedia(constraints);
        cameraFeed.srcObject = activeStream;
        await cameraFeed.play();

        snapBtn.disabled = false;
        cameraFeedWrap.hidden = false;
      } catch (err) {
        snapBtn.disabled = true;
        cameraFeedWrap.hidden = true;

        let message = 'Unable to access your camera. Please check browser permissions.';
        if (err.name === 'NotAllowedError' || err.name === 'PermissionDeniedError') {
          message = 'Camera access was denied. Please allow camera permissions in your browser settings and try again.';
        } else if (err.name === 'NotFoundError' || err.name === 'DevicesNotFoundError') {
          message = 'No camera was found on this device.';
        } else if (err.name === 'NotReadableError') {
          message = 'Your camera is in use by another application. Please close it and try again.';
        } else if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
          message = 'Your browser does not support camera access. Please use a modern browser.';
        }

        showCameraError(true, message);
      }
    }

    /** Stops all camera tracks */
    function stopCamera() {
      if (countdownTimer) {
        clearInterval(countdownTimer);
        countdownTimer = null;
      }
      countdownOverlay.hidden = true;

      if (activeStream) {
        activeStream.getTracks().forEach((t) => t.stop());
        activeStream = null;
      }
      cameraFeed.srcObject = null;
    }

    /** Shows or hides the camera error panel */
    function showCameraError(show, message = '') {
      cameraError.hidden = !show;
      if (show) cameraErrorText.textContent = message;
    }

    /* ── Close / Cancel ── */
    function closeModal() {
      stopCamera();
      cameraModal.close();
    }

    closeCameraBtn.addEventListener('click', closeModal);
    cancelCameraBtn.addEventListener('click', closeModal);

    // Close on backdrop click
    cameraModal.addEventListener('click', (e) => {
      if (e.target === cameraModal) closeModal();
    });

    // Close on Escape (native <dialog> handles this, but we also clean up stream)
    cameraModal.addEventListener('cancel', (e) => {
      e.preventDefault(); // prevent default close to run our cleanup
      closeModal();
    });

    /* ── Switch camera ── */
    switchCameraBtn.addEventListener('click', () => {
      facingMode = facingMode === 'user' ? 'environment' : 'user';
      startCamera();
    });

    /* ── Toggle timer ── */
    timerBtn.addEventListener('click', () => {
      timerEnabled = !timerEnabled;
      timerBtn.setAttribute('aria-pressed', String(timerEnabled));
    });

    /* ── Snap button ── */
    snapBtn.addEventListener('click', () => {
      if (timerEnabled) {
        runCountdownThenSnap();
      } else {
        captureFrame();
      }
    });

    /** 3-second countdown then auto-snap */
    function runCountdownThenSnap() {
      if (countdownTimer) return; // already counting

      snapBtn.disabled = true;
      let secs = 3;
      countdownNumber.style.animation = 'none';
      countdownNumber.textContent = String(secs);
      // Force reflow so animation restarts cleanly each tick
      void countdownNumber.offsetHeight;
      countdownNumber.style.animation = '';
      countdownOverlay.hidden = false;

      countdownTimer = setInterval(() => {
        secs--;
        if (secs <= 0) {
          clearInterval(countdownTimer);
          countdownTimer = null;
          countdownOverlay.hidden = true;
          snapBtn.disabled = false;
          captureFrame();
          return;
        }
        countdownNumber.style.animation = 'none';
        void countdownNumber.offsetHeight;
        countdownNumber.style.animation = '';
        countdownNumber.textContent = String(secs);
      }, 950);
    }

    /** Draws the current video frame to canvas and creates a File blob */
    function captureFrame() {
      if (!activeStream) return;

      const video = cameraFeed;
      const w = video.videoWidth  || 1280;
      const h = video.videoHeight || 720;

      captureCanvas.width  = w;
      captureCanvas.height = h;

      const ctx = captureCanvas.getContext('2d');

      // Mirror canvas so the saved image is NOT horizontally flipped
      // (CSS mirrored the live feed for UX, but we want the real orientation saved)
      ctx.save();
      ctx.translate(w, 0);
      ctx.scale(-1, 1);
      ctx.drawImage(video, 0, 0, w, h);
      ctx.restore();

      // Flash effect
      snapFlash.hidden = false;
      snapFlash.style.animation = 'none';
      void snapFlash.offsetHeight;
      snapFlash.style.animation = '';
      setTimeout(() => { snapFlash.hidden = true; }, 220);

      captureCanvas.toBlob((blob) => {
        if (!blob) return;
        selfieSerial++;
        const filename = `selfie-${selfieSerial}.png`;
        const file = new File([blob], filename, { type: 'image/png' });
        const objectUrl = URL.createObjectURL(blob);

        capturedSelfies.push({ file, objectUrl });
        renderSelfieStrip();
      }, 'image/png');
    }

    /* ── Render selfie thumbnail strip ── */
    function renderSelfieStrip() {
      selfieStrip.innerHTML = '';

      const count = capturedSelfies.length;
      selfieCountEl.textContent = count;
      useCountBadge.textContent = count;

      selfieStripWrap.hidden = count === 0;
      useSelfiesBtn.disabled = count === 0;

      capturedSelfies.forEach(({ objectUrl }, idx) => {
        const thumb = document.createElement('div');
        thumb.className = 'selfie-thumb';
        thumb.setAttribute('role', 'listitem');

        const img = document.createElement('img');
        img.src = objectUrl;
        img.alt = `Selfie ${idx + 1}`;

        const removeBtn = document.createElement('button');
        removeBtn.type = 'button';
        removeBtn.className = 'selfie-thumb-remove';
        removeBtn.setAttribute('aria-label', `Remove selfie ${idx + 1}`);
        removeBtn.textContent = '✕';
        removeBtn.addEventListener('click', () => removeSelfie(idx));

        thumb.append(img, removeBtn);
        selfieStrip.appendChild(thumb);
      });
    }

    /** Remove one selfie from the captured list */
    function removeSelfie(index) {
      const { objectUrl } = capturedSelfies[index];
      URL.revokeObjectURL(objectUrl);
      capturedSelfies.splice(index, 1);
      renderSelfieStrip();
    }

    /* ── Use selfies → inject into main selectedFiles[] ── */
    useSelfiesBtn.addEventListener('click', () => {
      if (!capturedSelfies.length) return;

      const remaining = MAX_IMAGES - selectedFiles.length;

      if (remaining <= 0) {
        // Close modal first, then show error
        closeModal();
        setMessage(`You already have ${MAX_IMAGES} photos selected. Remove some before adding selfies.`, 'error');
        return;
      }

      const toAdd = capturedSelfies.slice(0, remaining).map((s) => s.file);
      const skipped = capturedSelfies.length - toAdd.length;

      addFiles(toAdd, true /* isSelfie */);

      if (skipped > 0) {
        setMessage(`${skipped} selfie(s) were not added — maximum ${MAX_IMAGES} photos reached.`, 'error');
      }

      closeModal();
    });

    /* ─────────────── Initial render ─────────────── */
    renderPreview();
  </script>
</body>
</html>
