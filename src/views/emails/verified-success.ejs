<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Email Verified Successfully - Dating App</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: #0f172a; color: #f8fafc; display: flex; min-height: 100vh; align-items: center; justify-content: center; padding: 20px; }
    .card { background: #1e293b; border: 1px solid #334155; border-radius: 12px; padding: 40px 32px; width: 100%; max-width: 440px; box-shadow: 0 10px 25px rgba(0,0,0,0.3); text-align: center; }
    .icon { width: 80px; height: 80px; background: rgba(16, 185, 129, 0.15); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 24px auto; color: #10b981; font-size: 40px; animation: scaleIn 0.5s ease-out; }
    @keyframes scaleIn { 0% { transform: scale(0); opacity: 0; } 100% { transform: scale(1); opacity: 1; } }
    h1 { font-size: 24px; font-weight: 700; margin-bottom: 12px; color: #ffffff; }
    p.text { font-size: 15px; color: #94a3b8; line-height: 1.6; margin-bottom: 24px; }
    .email-badge { display: inline-block; background: #0f172a; border: 1px solid #047857; padding: 8px 16px; border-radius: 20px; color: #34d399; font-weight: 600; font-size: 14px; margin-bottom: 24px; word-break: break-all; }
    a.btn { display: inline-block; width: 100%; padding: 14px; font-size: 15px; font-weight: 600; background: #10b981; border-radius: 8px; color: #ffffff; text-decoration: none; transition: background 0.2s; margin-bottom: 12px; }
    a.btn:hover { background: #059669; }
    .redirect-note { font-size: 13px; color: #64748b; margin-top: 8px; }
    .redirect-note span { color: #10b981; font-weight: 600; }
  </style>
</head>
<body>
  <div class="card">
    <div class="icon">✓</div>
    <h1>Email Verified!</h1>
    <% if (typeof email !== 'undefined' && email) { %>
      <div class="email-badge"><%= email %></div>
    <% } %>
    <p class="text">Your email address has been confirmed. Your account is now fully active and ready to use.</p>
    <a href="/dashboard" class="btn" id="dashboardBtn">Continue to Dashboard</a>
    <p class="redirect-note">Redirecting automatically in <span id="countdown">5</span> seconds...</p>
  </div>

  <script>
    let seconds = 5;
    const countdownEl = document.getElementById('countdown');
    const interval = setInterval(() => {
      seconds--;
      countdownEl.textContent = seconds;
      if (seconds <= 0) {
        clearInterval(interval);
        window.location.href = '/dashboard';
      }
    }, 1000);
  </script>
</body>
</html>
