<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verify Your Email - Dating App</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: #0f172a; color: #f8fafc; display: flex; min-height: 100vh; align-items: center; justify-content: center; padding: 20px; }
    .card { background: #1e293b; border: 1px solid #334155; border-radius: 12px; padding: 36px 32px; width: 100%; max-width: 480px; box-shadow: 0 10px 25px rgba(0,0,0,0.3); text-align: center; }
    .icon { width: 64px; height: 64px; background: rgba(99, 102, 241, 0.15); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px auto; color: #818cf8; font-size: 32px; }
    h1 { font-size: 22px; font-weight: 700; margin-bottom: 12px; color: #ffffff; }
    p.text { font-size: 15px; color: #94a3b8; line-height: 1.6; margin-bottom: 20px; }
    .email-badge { display: inline-block; background: #0f172a; border: 1px solid #475569; padding: 8px 16px; border-radius: 20px; color: #38bdf8; font-weight: 600; font-size: 14px; margin-bottom: 24px; word-break: break-all; }
    .msg { padding: 12px; border-radius: 8px; font-size: 14px; margin-bottom: 20px; display: none; }
    .msg.success { background: #064e3b; border: 1px solid #047857; color: #a7f3d0; }
    .msg.error { background: #7f1d1d; border: 1px solid #991b1b; color: #fca5a5; }
    .troubleshoot { background: #0f172a; border: 1px solid #334155; border-radius: 8px; padding: 16px; text-align: left; margin: 24px 0; }
    .troubleshoot h3 { font-size: 14px; color: #cbd5e1; margin-bottom: 8px; font-weight: 600; }
    .troubleshoot ul { margin-left: 20px; font-size: 13px; color: #94a3b8; line-height: 1.6; }
    .actions { display: flex; flex-direction: column; gap: 12px; }
    button.btn-primary { width: 100%; padding: 12px; font-size: 15px; font-weight: 600; background: #4f46e5; border: none; border-radius: 8px; color: #ffffff; cursor: pointer; transition: background 0.2s; }
    button.btn-primary:hover { background: #4338ca; }
    a.btn-secondary { display: block; font-size: 14px; color: #94a3b8; text-decoration: none; padding: 8px; }
    a.btn-secondary:hover { color: #ffffff; text-decoration: underline; }
  </style>
</head>
<body>
  <div class="card">
    <div class="icon">✉️</div>
    <h1>Verify your email</h1>
    <p class="text">We sent a verification link to your email address. Please check your inbox and click the link to activate your account.</p>
    
    <% if (typeof email !== 'undefined' && email) { %>
      <div class="email-badge" id="userEmail"><%= email %></div>
    <% } %>

    <div id="responseMessage" class="msg"></div>

    <% if (typeof devVerificationLink !== 'undefined' && devVerificationLink) { %>
      <div style="background: #1a2332; border: 1px solid #f59e0b; border-radius: 8px; padding: 16px; margin-bottom: 20px; text-align: left;">
        <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 10px;">
          <span style="font-size: 18px;">⚠️</span>
          <strong style="color: #f59e0b; font-size: 14px;">Dev Mode — Firebase Rate Limited</strong>
        </div>
        <p style="font-size: 13px; color: #94a3b8; margin-bottom: 12px; line-height: 1.5;">
          Firebase email delivery is temporarily rate-limited. Click the button below to verify your account directly:
        </p>
        <a href="<%= devVerificationLink %>" style="display: block; text-align: center; padding: 10px 16px; background: #f59e0b; color: #0f172a; border-radius: 6px; font-weight: 700; font-size: 14px; text-decoration: none; transition: background 0.2s;" onmouseover="this.style.background='#d97706'" onmouseout="this.style.background='#f59e0b'">
          ✅ Verify Email Now (Dev Shortcut)
        </a>
      </div>
    <% } %>

    <div class="troubleshoot">
      <h3>Can't find the email?</h3>
      <ul>
        <li>Check your <strong>Spam</strong> or <strong>Junk</strong> folder.</li>
        <li>Check your <strong>Promotions</strong> or Updates tab.</li>
        <li>Wait a couple of minutes for delivery.</li>
      </ul>
    </div>

    <div class="actions">
      <form id="resendForm" action="/auth/resend-verification" method="POST">
        <% if (typeof csrfToken !== 'undefined') { %>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <% } %>
        <input type="hidden" name="email" value="<%= typeof email !== 'undefined' ? email : '' %>">
        <button type="submit" class="btn-primary" id="resendBtn">Resend Verification Email</button>
      </form>

      <a href="/auth/signup" class="btn-secondary">Change email address</a>
      <a href="/auth/login" class="btn-secondary">Back to Login</a>
    </div>
  </div>

  <script>
    const form = document.getElementById('resendForm');
    const msg = document.getElementById('responseMessage');
    const btn = document.getElementById('resendBtn');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      btn.disabled = true;
      btn.textContent = 'Sending...';
      
      try {
        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());

        const res = await fetch('/auth/resend-verification', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(data)
        });

        const result = await res.json();

        msg.style.display = 'block';
        msg.className = 'msg ' + (result.success ? 'success' : 'error');
        msg.textContent = result.message || 'If an account exists, a verification email has been sent.';
      } catch (err) {
        msg.style.display = 'block';
        msg.className = 'msg success';
        msg.textContent = 'If an account exists, a verification email has been sent.';
      } finally {
        setTimeout(() => {
          btn.disabled = false;
          btn.textContent = 'Resend Verification Email';
        }, 3000);
      }
    });
  </script>
</body>
</html>
