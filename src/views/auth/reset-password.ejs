<%- include('../partials/auth-head', { title: 'Reset Password' }) %>
<body>
  <div class="auth-shell">
    <section class="auth-card" aria-label="Reset password form">
      <div class="brand"><strong>Update Password</strong></div>
      <p class="footer-note">Choose a new secure password and return to your dashboard safely.</p>

      <% if (error) { %>
        <div class="message-box error" role="alert"><%= error %></div>
      <% } %>

      <div id="form-error" class="message-box error" role="alert" aria-live="polite"></div>
      <div id="form-success" class="message-box success" role="status" aria-live="polite"></div>

      <form id="reset-password-form" novalidate>
        <div class="form-group">
          <label for="password">New Password</label>
          <input type="password" id="password" name="password" required autocomplete="new-password" minlength="8" placeholder="Minimum 8 characters" />
          <p class="field-message" aria-live="polite"></p>
          <p class="field-hint">At least 8 characters, no spaces. Keep it easy to remember but hard to guess.</p>
        </div>

        <button type="submit">Update Password</button>
      </form>
    </section>
  </div>

  <%- include('../partials/auth-footer') %>
  <script>
    const resetForm = document.getElementById('reset-password-form');
    const resetErrorBox = document.getElementById('form-error');
    const resetSuccessBox = document.getElementById('form-success');
    const passwordField = resetForm.elements.password;

    function validateResetField() {
      clearFieldMessage(passwordField);
      const value = passwordField.value;

      if (!value.trim()) return showFieldMessage(passwordField, 'Password is required.');
      if (!isPasswordValid(value)) return showFieldMessage(passwordField, 'Password must be at least 8 characters and contain no spaces.');
      return showFieldMessage(passwordField, 'Password is strong enough.', 'success');
    }

    function validateResetForm() {
      let valid = true;
      clearFormStatus(resetForm);
      clearFieldMessage(passwordField);

      if (!passwordField.value.trim()) {
        showFieldMessage(passwordField, 'Password is required.');
        valid = false;
      } else if (!isPasswordValid(passwordField.value)) {
        showFieldMessage(passwordField, 'Password must be at least 8 characters and contain no spaces.');
        valid = false;
      }

      if (!valid) {
        setFormStatus(resetErrorBox, 'Please update your password before continuing.', 'error');
        focusFirstInvalid(resetForm);
      }

      return valid;
    }

    passwordField.addEventListener('blur', validateResetField);
    passwordField.addEventListener('input', () => clearFieldMessage(passwordField));

    resetForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      clearFormStatus(resetForm);
      resetErrorBox.textContent = '';
      resetSuccessBox.textContent = '';

      if (!validateResetForm()) {
        return;
      }

      try {
        const response = await fetch('/auth/reset-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ password: passwordField.value })
        });

        const result = await response.json();

        if (!response.ok || !result.success) {
          setFormStatus(resetErrorBox, result.message || 'Reset failed.', 'error');
          return;
        }

        setFormStatus(resetSuccessBox, result.message || 'Password updated successfully.', 'success');
        setTimeout(() => {
          window.location.href = result.data.redirectTo;
        }, 1400);
      } catch {
        setFormStatus(resetErrorBox, 'Unable to reach the server. Please try again.', 'error');
      }
    });
  </script>
</body>
</html>
