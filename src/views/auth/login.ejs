<%- include('../partials/auth-head', { title: 'Login' }) %>
<body>
  <div class="auth-shell">
    <section class="auth-card" aria-label="Login form">
      <div class="brand"><strong>Sign In</strong></div>
      <p class="footer-note">Secure access to your account. Use your email and password to continue.</p>

      <div id="form-error" class="message-box error" role="alert" aria-live="polite"></div>

      <form id="login-form" novalidate>
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required autocomplete="email" placeholder="name@example.com" />
          <p class="field-message" aria-live="polite"></p>
        </div>

        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" required autocomplete="current-password" placeholder="••••••••" />
          <p class="field-message" aria-live="polite"></p>
        </div>

        <button type="submit">Log In</button>
      </form>

      <a class="social-button" href="/auth/google">Continue with Google</a>

      <div class="page-links">
        <a href="/auth/forgot-password">Forgot password?</a>
        <a href="/auth/register">Create an account</a>
      </div>
    </section>
  </div>

  <%- include('../partials/auth-footer') %>
  <script>
    const loginForm = document.getElementById('login-form');
    const loginErrorBox = document.getElementById('form-error');
    const emailField = loginForm.elements.email;
    const passwordField = loginForm.elements.password;

    function validateLoginField(field) {
      clearFieldMessage(field);
      const value = field.value.trim();

      if (field === emailField) {
        if (!value) return showFieldMessage(field, 'Email is required.');
        if (!isEmailValid(value)) return showFieldMessage(field, 'Enter a valid email address.');
        return showFieldMessage(field, 'Looks good.', 'success');
      }

      if (field === passwordField) {
        if (!value) return showFieldMessage(field, 'Password is required.');
        return null;
      }
    }

    function validateLoginForm() {
      let valid = true;
      loginErrorBox.textContent = '';
      clearFieldMessage(emailField);
      clearFieldMessage(passwordField);

      if (!emailField.value.trim()) {
        showFieldMessage(emailField, 'Email is required.');
        valid = false;
      } else if (!isEmailValid(emailField.value)) {
        showFieldMessage(emailField, 'Enter a valid email address.');
        valid = false;
      }

      if (!passwordField.value.trim()) {
        showFieldMessage(passwordField, 'Password is required.');
        valid = false;
      }

      if (!valid) {
        setFormStatus(loginErrorBox, 'Please fix the highlighted fields.', 'error');
        focusFirstInvalid(loginForm);
      }

      return valid;
    }

    emailField.addEventListener('blur', () => validateLoginField(emailField));
    passwordField.addEventListener('blur', () => validateLoginField(passwordField));
    emailField.addEventListener('input', () => clearFieldMessage(emailField));
    passwordField.addEventListener('input', () => clearFieldMessage(passwordField));

    loginForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      clearFormStatus(loginForm);

      if (!validateLoginForm()) {
        return;
      }

      const payload = {
        email: emailField.value.trim(),
        password: passwordField.value
      };

      try {
        const response = await fetch('/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        const result = await response.json();

        if (!response.ok || !result.success) {
          setFormStatus(loginErrorBox, result.message || 'Login failed.', 'error');
          return;
        }

        window.location.href = result.data.redirectTo;
      } catch {
        setFormStatus(loginErrorBox, 'Unable to reach the server. Please try again.', 'error');
      }
    });
  </script>
</body>
</html>
