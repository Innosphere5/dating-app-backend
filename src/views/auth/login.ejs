<%- include('../partials/auth-head', { title: 'Login' }) %>
<style>
  .auth-tabs {
    display: flex;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
    gap: 1rem;
  }
  .auth-tab {
    flex: 1;
    padding: 0.75rem;
    text-align: center;
    cursor: pointer;
    font-weight: 600;
    color: var(--muted);
    border-bottom: 2px solid transparent;
    transition: all 180ms ease;
  }
  .auth-tab.active {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
  .tab-content {
    display: none;
  }
  .tab-content.active {
    display: block;
  }
</style>
<body>
  <div class="auth-shell">
    <section class="auth-card" aria-label="Login form">
      <div class="brand"><strong>Sign In</strong></div>
      <p class="footer-note">Secure access to your account. Choose email or phone number to continue.</p>

      <div class="auth-tabs">
        <div class="auth-tab active" onclick="switchTab('email')">Email</div>
        <div class="auth-tab" onclick="switchTab('phone')">Phone</div>
      </div>

      <div id="form-error" class="message-box error" role="alert" aria-live="polite"></div>

      <!-- Email Tab Content -->
      <div id="email-tab" class="tab-content active">
        <form id="login-form" novalidate>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required autocomplete="email" placeholder="name@example.com" />
            <p class="field-message" aria-live="polite"></p>
          </div>

          <div class="form-group">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" required autocomplete="current-password" placeholder="••••••••" />
            <p class="field-message" aria-live="polite"></p>
          </div>

          <button type="submit">Log In</button>
        </form>
      </div>

      <!-- Phone Tab Content -->
      <div id="phone-tab" class="tab-content">
        <form id="phone-login-form" novalidate>
          <div class="form-group">
            <label for="phone">Phone Number (10 digits)</label>
            <input type="tel" id="phone" name="phone" required maxlength="10" placeholder="e.g. 9876543210" />
            <p class="field-message" aria-live="polite"></p>
          </div>

          <button type="submit">Log In</button>
        </form>
      </div>

      <button type="button" class="social-button" id="google-login-btn">Continue with Google</button>

      <div class="page-links">
        <a href="/auth/forgot-password">Forgot password?</a>
        <a href="/auth/register">Create an account</a>
      </div>
    </section>
  </div>

  <%- include('../partials/auth-footer') %>
  <script>
    const loginForm = document.getElementById('login-form');
    const loginErrorBox = document.getElementById('form-error');
    const emailField = loginForm.elements.email;
    const passwordField = loginForm.elements.password;

    const phoneLoginForm = document.getElementById('phone-login-form');
    const phoneField = phoneLoginForm.elements.phone;

    function switchTab(type) {
      document.querySelectorAll('.auth-tab').forEach(tab => tab.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
      
      loginErrorBox.textContent = '';
      loginErrorBox.classList.remove('error', 'success');
      
      clearFieldMessage(emailField);
      clearFieldMessage(passwordField);
      clearFieldMessage(phoneField);

      if (type === 'email') {
        document.querySelector('.auth-tab:nth-child(1)').classList.add('active');
        document.getElementById('email-tab').classList.add('active');
      } else {
        document.querySelector('.auth-tab:nth-child(2)').classList.add('active');
        document.getElementById('phone-tab').classList.add('active');
      }
    }

    function validateLoginField(field) {
      clearFieldMessage(field);
      const value = field.value.trim();

      if (field === emailField) {
        if (!value) return showFieldMessage(field, 'Email is required.');
        if (!isEmailValid(value)) return showFieldMessage(field, 'Enter a valid email address.');
        return showFieldMessage(field, 'Looks good.', 'success');
      }

      if (field === passwordField) {
        if (!value) return showFieldMessage(field, 'Password is required.');
        return null;
      }
    }

    function validatePhoneField(field) {
      clearFieldMessage(field);
      const value = field.value.trim();
      if (!value) return showFieldMessage(field, 'Phone number is required.');
      if (!/^\d{10}$/.test(value)) return showFieldMessage(field, 'Phone number must be exactly 10 digits.');
      return showFieldMessage(field, 'Looks good.', 'success');
    }

    function validateLoginForm() {
      let valid = true;
      loginErrorBox.textContent = '';
      loginErrorBox.classList.remove('error', 'success');
      clearFieldMessage(emailField);
      clearFieldMessage(passwordField);

      if (!emailField.value.trim()) {
        showFieldMessage(emailField, 'Email is required.');
        valid = false;
      } else if (!isEmailValid(emailField.value)) {
        showFieldMessage(emailField, 'Enter a valid email address.');
        valid = false;
      }

      if (!passwordField.value.trim()) {
        showFieldMessage(passwordField, 'Password is required.');
        valid = false;
      }

      if (!valid) {
        setFormStatus(loginErrorBox, 'Please fix the highlighted fields.', 'error');
        focusFirstInvalid(loginForm);
      }

      return valid;
    }

    emailField.addEventListener('blur', () => validateLoginField(emailField));
    passwordField.addEventListener('blur', () => validateLoginField(passwordField));
    emailField.addEventListener('input', () => clearFieldMessage(emailField));
    passwordField.addEventListener('input', () => clearFieldMessage(passwordField));

    phoneField.addEventListener('blur', () => validatePhoneField(phoneField));
    phoneField.addEventListener('input', () => clearFieldMessage(phoneField));

    loginForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      clearFormStatus(loginForm);

      if (!validateLoginForm()) {
        return;
      }

      const payload = {
        email: emailField.value.trim(),
        password: passwordField.value
      };

      try {
        const response = await fetch('/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        const result = await response.json();

        if (!response.ok || !result.success) {
          setFormStatus(loginErrorBox, result.message || 'Login failed.', 'error');
          return;
        }

        window.location.href = result.data.redirectTo;
      } catch {
        setFormStatus(loginErrorBox, 'Unable to reach the server. Please try again.', 'error');
      }
    });

    phoneLoginForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      clearFormStatus(phoneLoginForm);

      const value = phoneField.value.trim();
      if (!value) {
        showFieldMessage(phoneField, 'Phone number is required.');
        setFormStatus(loginErrorBox, 'Please fix the highlighted fields.', 'error');
        return;
      }
      if (!/^\d{10}$/.test(value)) {
        showFieldMessage(phoneField, 'Phone number must be exactly 10 digits.');
        setFormStatus(loginErrorBox, 'Please fix the highlighted fields.', 'error');
        return;
      }

      try {
        const response = await fetch('/auth/phone-login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ phone: value })
        });

        const result = await response.json();

        if (!response.ok || !result.success) {
          setFormStatus(loginErrorBox, result.message || 'Login failed.', 'error');
          return;
        }

        window.location.href = result.data.redirectTo;
      } catch {
        setFormStatus(loginErrorBox, 'Unable to reach the server. Please try again.', 'error');
      }
    });
  </script>
  <script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
    import { getAuth, signInWithPopup, GoogleAuthProvider } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-auth.js";

    const firebaseConfig = {
      apiKey: "AIzaSyCDAASSUvUFbfSaE-Upc4-289LQrvavvd8",
      authDomain: "dating-app-backend-d34a4.firebaseapp.com",
      projectId: "dating-app-backend-d34a4",
      storageBucket: "dating-app-backend-d34a4.firebasestorage.app",
      messagingSenderId: "536983423340",
      appId: "1:536983423340:web:af664c1b70bac5496a0b49",
      measurementId: "G-YN0QD1XMHR"
    };

    const app = initializeApp(firebaseConfig);
    const auth = getAuth(app);
    const provider = new GoogleAuthProvider();

    document.getElementById('google-login-btn').addEventListener('click', async () => {
      const loginErrorBox = document.getElementById('form-error');
      loginErrorBox.textContent = '';
      loginErrorBox.classList.remove('error', 'success');

      try {
        const result = await signInWithPopup(auth, provider);
        const idToken = await result.user.getIdToken();
        const refreshToken = result.user.refreshToken;

        const response = await fetch('/auth/google/session', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            access_token: idToken,
            refresh_token: refreshToken,
            expires_in: 3600
          })
        });

        const resData = await response.json();
        if (resData.success) {
          window.location.href = resData.redirectTo || '/dashboard';
        } else {
          loginErrorBox.textContent = resData.message || 'Google sign-in failed.';
          loginErrorBox.classList.add('error');
        }
      } catch (err) {
        console.error(err);
        loginErrorBox.textContent = 'Google sign-in was cancelled or failed.';
        loginErrorBox.classList.add('error');
      }
    });
  </script>
</body>
</html>
