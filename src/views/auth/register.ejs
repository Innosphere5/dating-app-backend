<%- include('../partials/auth-head', { title: 'Register' }) %>
<style>
  .auth-tabs {
    display: flex;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
    gap: 1rem;
  }
  .auth-tab {
    flex: 1;
    padding: 0.75rem;
    text-align: center;
    cursor: pointer;
    font-weight: 600;
    color: var(--muted);
    border-bottom: 2px solid transparent;
    transition: all 180ms ease;
  }
  .auth-tab.active {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
  .tab-content {
    display: none;
  }
  .tab-content.active {
    display: block;
  }
</style>
<body>
  <div class="auth-shell">
    <section class="auth-card" aria-label="Register form">
      <div class="brand"><strong>Create Account</strong></div>
      <p class="footer-note">Sign up to get started. Choose email or phone number to continue.</p>

      <div class="auth-tabs">
        <div class="auth-tab active" onclick="switchTab('email')">Email</div>
        <div class="auth-tab" onclick="switchTab('phone')">Phone</div>
      </div>

      <div id="form-error" class="message-box error" role="alert" aria-live="polite"></div>
      <div id="form-success" class="message-box success" role="status" aria-live="polite"></div>

      <!-- Email Tab Content -->
      <div id="email-tab" class="tab-content active">
        <form id="register-form" novalidate>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required autocomplete="email" placeholder="name@example.com" />
            <p class="field-message" aria-live="polite"></p>
          </div>

          <div class="form-group">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" required autocomplete="new-password" minlength="8" placeholder="Minimum 8 characters" />
            <p class="field-message" aria-live="polite"></p>
            <p class="field-hint">Use 8+ characters with no spaces for the best balance of security and ease.</p>
          </div>

          <button type="submit">Register</button>
        </form>
      </div>

      <!-- Phone Tab Content -->
      <div id="phone-tab" class="tab-content">
        <form id="phone-register-form" novalidate>
          <div class="form-group">
            <label for="phone">Phone Number (10 digits)</label>
            <input type="tel" id="phone" name="phone" required maxlength="10" placeholder="e.g. 9876543210" />
            <p class="field-message" aria-live="polite"></p>
          </div>

          <button type="submit">Register</button>
        </form>
      </div>

      <a class="social-button" href="/auth/google">Continue with Google</a>

      <div class="page-links">
        <a href="/auth/login">Already have an account?</a>
      </div>
    </section>
  </div>

  <%- include('../partials/auth-footer') %>
  <script>
    const registerForm = document.getElementById('register-form');
    const registerErrorBox = document.getElementById('form-error');
    const registerSuccessBox = document.getElementById('form-success');
    const emailField = registerForm.elements.email;
    const passwordField = registerForm.elements.password;

    const phoneRegisterForm = document.getElementById('phone-register-form');
    const phoneField = phoneRegisterForm.elements.phone;

    function switchTab(type) {
      document.querySelectorAll('.auth-tab').forEach(tab => tab.classList.remove('active'));
      document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
      
      registerErrorBox.textContent = '';
      registerErrorBox.classList.remove('error', 'success');
      registerSuccessBox.textContent = '';
      registerSuccessBox.classList.remove('error', 'success');
      
      clearFieldMessage(emailField);
      clearFieldMessage(passwordField);
      clearFieldMessage(phoneField);

      if (type === 'email') {
        document.querySelector('.auth-tab:nth-child(1)').classList.add('active');
        document.getElementById('email-tab').classList.add('active');
      } else {
        document.querySelector('.auth-tab:nth-child(2)').classList.add('active');
        document.getElementById('phone-tab').classList.add('active');
      }
    }

    function validateRegisterField(field) {
      clearFieldMessage(field);
      const value = field.value.trim();

      if (field === emailField) {
        if (!value) return showFieldMessage(field, 'Email is required.');
        if (!isEmailValid(value)) return showFieldMessage(field, 'Enter a valid email address.');
        return showFieldMessage(field, 'Valid email address.', 'success');
      }

      if (field === passwordField) {
        if (!value) return showFieldMessage(field, 'Password is required.');
        if (!isPasswordValid(value)) return showFieldMessage(field, 'Password must be at least 8 characters and contain no spaces.');
        return showFieldMessage(field, 'Password looks good.', 'success');
      }
    }

    function validatePhoneField(field) {
      clearFieldMessage(field);
      const value = field.value.trim();
      if (!value) return showFieldMessage(field, 'Phone number is required.');
      if (!/^\d{10}$/.test(value)) return showFieldMessage(field, 'Phone number must be exactly 10 digits.');
      return showFieldMessage(field, 'Looks good.', 'success');
    }

    function validateRegisterForm() {
      let valid = true;
      clearFormStatus(registerForm);
      clearFieldMessage(emailField);
      clearFieldMessage(passwordField);

      if (!emailField.value.trim()) {
        showFieldMessage(emailField, 'Email is required.');
        valid = false;
      } else if (!isEmailValid(emailField.value)) {
        showFieldMessage(emailField, 'Enter a valid email address.');
        valid = false;
      }

      if (!passwordField.value.trim()) {
        showFieldMessage(passwordField, 'Password is required.');
        valid = false;
      } else if (!isPasswordValid(passwordField.value)) {
        showFieldMessage(passwordField, 'Password must be at least 8 characters and contain no spaces.');
        valid = false;
      }

      if (!valid) {
        setFormStatus(registerErrorBox, 'Please review the form and correct any issues.', 'error');
        focusFirstInvalid(registerForm);
      }

      return valid;
    }

    emailField.addEventListener('blur', () => validateRegisterField(emailField));
    passwordField.addEventListener('blur', () => validateRegisterField(passwordField));
    emailField.addEventListener('input', () => clearFieldMessage(emailField));
    passwordField.addEventListener('input', () => clearFieldMessage(passwordField));

    phoneField.addEventListener('blur', () => validatePhoneField(phoneField));
    phoneField.addEventListener('input', () => clearFieldMessage(phoneField));

    registerForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      clearFormStatus(registerForm);
      registerErrorBox.textContent = '';
      registerSuccessBox.textContent = '';

      if (!validateRegisterForm()) {
        return;
      }

      const payload = {
        email: emailField.value.trim(),
        password: passwordField.value
      };

      try {
        const response = await fetch('/auth/register', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        const result = await response.json();

        if (!response.ok || !result.success) {
          setFormStatus(registerErrorBox, result.message || 'Registration failed.', 'error');
          return;
        }

        setFormStatus(registerSuccessBox, result.message || 'Registration successful. Check your email.', 'success');
        registerForm.reset();
      } catch {
        setFormStatus(registerErrorBox, 'Unable to reach the server. Please try again.', 'error');
      }
    });

    phoneRegisterForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      clearFormStatus(phoneRegisterForm);
      registerErrorBox.textContent = '';
      registerSuccessBox.textContent = '';

      const value = phoneField.value.trim();
      if (!value) {
        showFieldMessage(phoneField, 'Phone number is required.');
        setFormStatus(registerErrorBox, 'Please review the form and correct any issues.', 'error');
        return;
      }
      if (!/^\d{10}$/.test(value)) {
        showFieldMessage(phoneField, 'Phone number must be exactly 10 digits.');
        setFormStatus(registerErrorBox, 'Please review the form and correct any issues.', 'error');
        return;
      }

      try {
        const response = await fetch('/auth/phone-register', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ phone: value })
        });

        const result = await response.json();

        if (!response.ok || !result.success) {
          setFormStatus(registerErrorBox, result.message || 'Registration failed.', 'error');
          return;
        }

        setFormStatus(registerSuccessBox, result.message || 'Registration successful. You can now sign in.', 'success');
        phoneRegisterForm.reset();
      } catch {
        setFormStatus(registerErrorBox, 'Unable to reach the server. Please try again.', 'error');
      }
    });
  </script>
</body>
</html>
