<%- include('../partials/auth-head', { title: 'Forgot Password' }) %>
<body>
  <div class="auth-shell">
    <section class="auth-card" aria-label="Forgot password form">
      <div class="brand"><strong>Reset Password</strong></div>
      <p class="footer-note">Enter the email address associated with your account and we’ll send a reset link.</p>

      <div id="form-error" class="message-box error" role="alert" aria-live="polite"></div>
      <div id="form-success" class="message-box success" role="status" aria-live="polite"></div>

      <form id="forgot-password-form" novalidate>
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required autocomplete="email" placeholder="name@example.com" />
          <p class="field-message" aria-live="polite"></p>
        </div>

        <button type="submit">Send Reset Link</button>
      </form>

      <div class="page-links">
        <a href="/auth/login">Back to login</a>
      </div>
    </section>
  </div>

  <%- include('../partials/auth-footer') %>
  <script>
    const forgotForm = document.getElementById('forgot-password-form');
    const forgotErrorBox = document.getElementById('form-error');
    const forgotSuccessBox = document.getElementById('form-success');
    const emailField = forgotForm.elements.email;

    function validateForgotField() {
      clearFieldMessage(emailField);
      const value = emailField.value.trim();

      if (!value) return showFieldMessage(emailField, 'Email is required.');
      if (!isEmailValid(value)) return showFieldMessage(emailField, 'Enter a valid email address.');
      return showFieldMessage(emailField, 'Ready to send reset instructions.', 'success');
    }

    function validateForgotForm() {
      let valid = true;
      clearFormStatus(forgotForm);
      clearFieldMessage(emailField);

      if (!emailField.value.trim()) {
        showFieldMessage(emailField, 'Email is required.');
        valid = false;
      } else if (!isEmailValid(emailField.value)) {
        showFieldMessage(emailField, 'Enter a valid email address.');
        valid = false;
      }

      if (!valid) {
        setFormStatus(forgotErrorBox, 'Please correct your email before continuing.', 'error');
        focusFirstInvalid(forgotForm);
      }

      return valid;
    }

    emailField.addEventListener('blur', validateForgotField);
    emailField.addEventListener('input', () => clearFieldMessage(emailField));

    forgotForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      clearFormStatus(forgotForm);
      forgotErrorBox.textContent = '';
      forgotSuccessBox.textContent = '';

      if (!validateForgotForm()) {
        return;
      }

      try {
        const response = await fetch('/auth/forgot-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: emailField.value.trim() })
        });

        const result = await response.json();

        if (!response.ok || !result.success) {
          setFormStatus(forgotErrorBox, result.message || 'Request failed.', 'error');
          return;
        }

        setFormStatus(forgotSuccessBox, result.message || 'If your email exists, a reset link has been sent.', 'success');
      } catch {
        setFormStatus(forgotErrorBox, 'Unable to reach the server. Please try again.', 'error');
      }
    });
  </script>
</body>
</html>
