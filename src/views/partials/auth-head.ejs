<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <style>
    :root {
      color-scheme: dark;
      font-family:
        Inter,
        system-ui,
        -apple-system,
        BlinkMacSystemFont,
        "Segoe UI",
        sans-serif;
      --surface: rgba(15, 23, 42, 0.95);
      --surface-strong: rgba(15, 23, 42, 0.98);
      --border: rgba(148, 163, 184, 0.18);
      --text: #e2e8f0;
      --muted: #94a3b8;
      --accent: #38bdf8;
      --accent-strong: #0ea5e9;
      --danger: #f87171;
      --success: #22c55e;
    }

    *,
    *::before,
    *::after {
      box-sizing: border-box;
    }

    html,
    body {
      margin: 0;
      min-height: 100%;
      background:
        radial-gradient(
          circle at top left,
          rgba(56, 189, 248, 0.18),
          transparent 34%
        ),
        radial-gradient(
          circle at bottom right,
          rgba(16, 185, 129, 0.16),
          transparent 28%
        ),
        linear-gradient(180deg, #020617 0%, #0f172a 100%);
      color: var(--text);
    }

    body {
      display: grid;
      place-items: center;
      min-height: 100vh;
      padding: 24px;
    }

    button,
    input,
    a {
      font: inherit;
    }

    .auth-shell {
      width: min(520px, 100%);
      margin: 0 auto;
    }

    .auth-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 28px;
      box-shadow: 0 36px 90px rgba(0, 0, 0, 0.22);
      padding: 34px 34px 28px;
      backdrop-filter: blur(18px);
    }

    .brand {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      margin-bottom: 1rem;
    }

    .brand strong {
      font-size: 0.95rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--accent);
    }

    h1 {
      margin: 0;
      font-size: clamp(2rem, 4vw, 2.4rem);
      line-height: 1.05;
      color: #f8fafc;
    }

    .footer-note {
      margin: 0.75rem 0 1.75rem;
      color: var(--muted);
      line-height: 1.6;
      font-size: 0.95rem;
    }

    .form-group {
      display: grid;
      gap: 0.5rem;
      margin-bottom: 1rem;
    }

    label {
      font-size: 0.95rem;
      color: #cbd5e1;
    }

    input {
      width: 100%;
      min-height: 50px;
      padding: 0 1.05rem;
      border-radius: 16px;
      border: 1px solid rgba(148, 163, 184, 0.18);
      background: rgba(15, 23, 42, 0.72);
      color: #f8fafc;
      transition:
        border-color 180ms ease,
        box-shadow 180ms ease,
        transform 180ms ease;
    }

    input:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: 0 0 0 6px rgba(56, 189, 248, 0.14);
      transform: translateY(-0.5px);
    }

    .input-error {
      border-color: rgba(248, 113, 113, 0.95) !important;
      box-shadow: 0 0 0 6px rgba(248, 113, 113, 0.14);
    }

    .field-message {
      min-height: 1.15rem;
      font-size: 0.88rem;
      color: var(--muted);
    }

    .field-message.error {
      color: #fecaca;
    }

    .field-message.success {
      color: #bbf7d0;
    }

    .field-hint {
      margin: 0.15rem 0 0;
      color: #94a3b8;
      font-size: 0.85rem;
    }

    .message-box {
      display: none;
      width: 100%;
      border-radius: 18px;
      padding: 1rem 1rem;
      margin-bottom: 1rem;
      font-size: 0.96rem;
      line-height: 1.5;
    }

    .message-box.error,
    .message-box.success {
      display: block;
    }

    .message-box.error {
      background: rgba(248, 113, 113, 0.16);
      border: 1px solid rgba(248, 113, 113, 0.28);
      color: #fee2e2;
    }

    .message-box.success {
      background: rgba(52, 211, 153, 0.14);
      border: 1px solid rgba(52, 211, 153, 0.28);
      color: #d1fae5;
    }

    button,
    .social-button {
      width: 100%;
      min-height: 52px;
      border-radius: 16px;
      border: none;
      cursor: pointer;
      font-weight: 700;
      letter-spacing: 0.01em;
      transition:
        transform 180ms ease,
        background 180ms ease,
        box-shadow 180ms ease;
    }

    button {
      background: linear-gradient(135deg, var(--accent), var(--accent-strong));
      color: #0f172a;
      box-shadow: 0 18px 34px rgba(14, 165, 233, 0.16);
    }

    button:hover,
    .social-button:hover {
      transform: translateY(-1px);
    }

    button:disabled {
      opacity: 0.65;
      cursor: not-allowed;
      transform: none;
      background: rgba(56, 189, 248, 0.35);
    }

    .social-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      background: rgba(255, 255, 255, 0.08);
      color: #f8fafc;
      border: 1px solid rgba(148, 163, 184, 0.22);
      margin-top: 0.5rem;
      text-decoration: none;
    }

    .page-links {
      display: grid;
      gap: 0.7rem;
      margin-top: 1.25rem;
    }

    .page-links a {
      color: #cbd5e1;
      text-decoration: none;
      transition: color 180ms ease;
      font-size: 0.95rem;
    }

    .page-links a:hover {
      color: #ffffff;
    }

    @media (max-width: 520px) {
      body {
        padding: 16px;
      }

      .auth-card {
        padding: 26px 22px 22px;
      }
    }
  </style>
</head>
